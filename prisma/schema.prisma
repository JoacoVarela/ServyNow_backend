generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model professional {
  id          String   @id @db.Char(36)
  firstName   String   @db.VarChar(255)
  lastName    String   @db.VarChar(255)
  email       String   @unique(map: "email") @db.VarChar(255)
  phoneNumber String?  @db.VarChar(50)
  bio         String?  @db.Text
  rating      Float    @default(0) @db.Float
  createdAt   DateTime @default(now()) @db.DateTime(0)
  updatedAt   DateTime @default(now()) @db.DateTime(0)
  review      review[]
}

model review {
  id             String       @id @db.Char(36)
  professionalId String       @db.Char(36)
  reviewerName   String       @db.VarChar(255)
  rating         Float        @db.Float
  comment        String?      @db.Text
  createdAt      DateTime     @default(now()) @db.DateTime(0)
  professional   professional @relation(fields: [professionalId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_professional")

  @@index([professionalId], map: "fk_professional")
}
